# 🔐 Database Configuration Template
#
# INSTRUCTIONS:
# 1. Copy this file to .env (do NOT commit .env to git)
# 2. Fill in your MariaDB credentials below
# 3. Set these as environment variables before running Maven
#
# IMPORTANT: Never commit .env or hardcode passwords in source code!

# MariaDB Host (typically 'localhost' for local development)
DB_HOST=localhost

# MariaDB Port (default is 3306)
DB_PORT=3306

# Database Name
DB_NAME=shopping_cart_localization

# Database Username
DB_USER=root

# Database Password - FILL THIS IN WITH YOUR ACTUAL PASSWORD
DB_PASSWORD=your_mariadb_root_password_here

